generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  CLIENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(CLIENT)
  avatar    String?
  orders    Order[]
  reviews   Review[]
  wishlist  WishlistItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]
  navbarItemId String?
  navbarItem   NavbarItem? @relation(fields: [navbarItemId], references: [id])
  orderIndex  Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  description     String?     @db.Text
  shortDesc       String?
  price           Float
  compareAtPrice  Float?
  stock           Int         @default(0)
  sku             String?     @unique
  images          String[]
  categoryId      String?
  category        Category?   @relation(fields: [categoryId], references: [id])
  isPromotion     Boolean     @default(false)
  discountPercent Int?
  promotionEnd    DateTime?
  isFeatured      Boolean     @default(false)
  isNew           Boolean     @default(true)
  isPopular       Boolean     @default(false)
  isActive        Boolean     @default(true)
  viewCount       Int         @default(0)
  orderItems      OrderItem[]
  reviews         Review[]
  wishlistItems   WishlistItem[]
  tags            String[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Order {
  id           String      @id @default(cuid())
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  status       OrderStatus @default(PENDING)
  items        OrderItem[]
  totalAmount  Float
  shippingCost Float       @default(0)
  fullName     String
  phone        String
  city         String
  address      String
  notes        String?
  whatsappSent Boolean     @default(false)
  couponCode   String?
  discount     Float?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  name      String
}

model HeroSlide {
  id         String  @id @default(cuid())
  image      String
  title      String
  subtitle   String?
  buttonText String?
  buttonLink String?
  orderIndex Int     @default(0)
  isActive   Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model NavbarItem {
  id         String     @id @default(cuid())
  label      String
  href       String
  orderIndex Int        @default(0)
  isActive   Boolean    @default(true)
  isMegaMenu Boolean    @default(false)
  categories Category[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Activity {
  id          String  @id @default(cuid())
  title       String
  image       String?
  description String?
  buttonText  String  @default("Découvrir")
  buttonLink  String?
  orderIndex  Int     @default(0)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Promotion {
  id              String   @id @default(cuid())
  title           String
  description     String?
  image           String?
  discountPercent Int
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  size      Int
  mimeType  String
  alt       String?
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  rating    Int
  comment   String?  @db.Text
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Int
  minOrder        Float?
  maxUses         Int?
  usedCount       Int       @default(0)
  isActive        Boolean   @default(true)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}
